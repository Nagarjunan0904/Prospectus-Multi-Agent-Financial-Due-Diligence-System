OPENAI_API_KEY=sk-proj-...
SEC_EDGAR_USER_AGENT="YourName your.email@example.com"   # SEC requires a real UA string
ALPHAVANTAGE_API_KEY=...          # news headlines, free tier
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/prospectus
# All 4 MCP agents + FastAPI now run as separate processes inside ONE
# container (managed by supervisord), sharing its network namespace — so
# these always point at localhost, whether running locally or deployed.
MCP_DATA_AGENT_URL=http://localhost:9001/mcp
MCP_DATA_AGENT_TOKEN=change-me-in-production  # static bearer token (dev only — swap for OAuth 2.1 in prod)
MCP_QUANT_AGENT_URL=http://localhost:9002/mcp
MCP_QUANT_AGENT_TOKEN=change-me-in-production
MCP_SENTIMENT_AGENT_URL=http://localhost:9003/mcp
MCP_SENTIMENT_AGENT_TOKEN=change-me-in-production
MCP_RISK_AGENT_URL=http://localhost:9004/mcp
MCP_RISK_AGENT_TOKEN=change-me-in-production
LANGSMITH_API_KEY=...             # optional, LangGraph tracing